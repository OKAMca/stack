    "react": "^18.0.0 || ^19.0.0",
    "react-stately": "^3.43.0"
  },
  "dependencies": {
    "@okam/react-utils": "workspace:*",
    "@okam/stack-ui": "workspace:*",
    "nuqs": "^2.9.1",
    "radashi": "^12.9.1",
    "react-aria": "^3.50.0",
